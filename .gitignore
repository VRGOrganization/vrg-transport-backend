# =============================================================================
# VARIÁVEIS DE AMBIENTE — regra crítica de segurança
# =============================================================================
# Bloqueia todos os arquivos .env por padrão.
# Libera apenas o .env.example (template sem valores reais).
#
# Se você acidentalmente commitou um .env com segredos:
#   1. Rotacione TODOS os segredos imediatamente (JWT, DB, API keys)
#   2. Remova do histórico: git filter-repo --path .env --invert-paths
#   3. Force-push e avise todos os colaboradores para rebaser
# =============================================================================
.env
.env.*
!.env.example


# -----------------------------------------------------------------------------
# Node / NestJS
# -----------------------------------------------------------------------------
node_modules/
dist/
build/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Cache
.npm
.eslintcache
.nyc_output
coverage/

# -----------------------------------------------------------------------------
# IDEs e editores
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Sistema operacional
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
scripts/seed-admin.ts