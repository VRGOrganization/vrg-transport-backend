# ── Banco de dados ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/Transport-Api
MONGODB_URI_IMAGE=mongodb+srv://user:password@cluster.mongodb.net/transport-images
DBPASSWORD=sua_senha_do_banco

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use um segredo longo e aleatório em produção:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_muito_longo_e_aleatorio
JWT_EXPIRES_IN=8h

# ── E-mail ────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.seu-provedor.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seu@email.com
MAIL_PASS=sua_senha_de_email
MAIL_FROM_NAME=VRG Transport

# ── Licença ───────────────────────────────────────────────────────────────────
BASE_URL_API_LICENSE=https://api-de-licencas.com
X_API_KEY=sua_chave_da_api_de_licencas

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
# Em produção, liste as origens permitidas separadas por vírgula:
# ALLOWED_ORIGINS=https://seu-frontend.com,https://app.seu-dominio.com
ALLOWED_ORIGINS=*

# ── Seed do admin (usado apenas pelo script seed-admin.ts) ────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SenhaForte123
ADMIN_NAME=Administrador
