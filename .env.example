# AMBIENTE
NODE_ENV=development


# SERVIDOR
# CORS — aceita frontend local nas portas comuns de dev
ALLOWED_ORIGINS=*
PORT=3000

# BANCO DE DADOS — MongoDB local
SERDB=
DBPASSWORD=
# Transport-Api-BD
MONGODB_URI=
# Transport-Images-BD
MONGODB_URI_IMAGE=

LICENSE_API_URL=
LICENSE_API_KEY=
LICENSE_API_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# JWT — Access Token
# Valor longo o suficiente para passar a validação mínima de 32 chars.
# NÃO use estes valores em produção.
JWT_SECRET=
JWT_EXPIRES_IN=



# JWT — Refresh Token
# Secret diferente do JWT_SECRET, mesmo em desenvolvimento.
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=



# OTP — Pepper
OTP_PEPPER=



# E-MAIL — Mailpit (captura local, não envia de verdade)
# Acesse os e-mails em http://localhost:8025
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=dev@local.test
MAIL_PASS=qualquer-valor-mailpit-nao-autentica
MAIL_FROM_NAME=VRG Transport Dev

# ── SIGHT-API
API_USER_SIGHT=1344625949
API_KEY_SIGHT=HYqVi9mYXfWSwMhhsLmtxajFhfNDpiUd

# SWAGGER — habilita documentação da API em desenvolvimento
ENABLE_SWAGGER=true

TRUST_PROXY_HOPS=0