# AMBIENTE
NODE_ENV=development


# SERVIDOR
# CORS — aceita frontend local nas portas comuns de dev
ALLOWED_ORIGINS=*
PORT=3000

# BANCO DE DADOS — MongoDB local
SERDB=
DBPASSWORD=
# Transport-Api-BD
MONGODB_URI=
# Transport-Images-BD
MONGODB_URI_IMAGE=

LICENSE_API_URL=
LICENSE_API_KEY=
LICENSE_API_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# JWT — Access Token
# Valor longo o suficiente para passar a validação mínima de 32 chars.
# NÃO use estes valores em produção.
JWT_SECRET=
JWT_EXPIRES_IN=



# JWT — Refresh Token
# Secret diferente do JWT_SECRET, mesmo em desenvolvimento.
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=



# OTP — Pepper
OTP_PEPPER=



# E-MAIL — Brevo
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
MAIL_FROM_NAME=VRG Transport
MAIL_FROM_ADDRESS=noreply@seudominio.com.br


# ── SIGHT-API
API_USER_SIGHT=1344625949
API_KEY_SIGHT=HYqVi9mYXfWSwMhhsLmtxajFhfNDpiUd

# SWAGGER — habilita documentação da API em desenvolvimento
ENABLE_SWAGGER=true

TRUST_PROXY_HOPS=0